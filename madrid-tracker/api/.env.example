# Copy this to .env (never commit .env!)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
IDEALISTA_API_KEY=your_idealista_api_key
IDEALISTA_SECRET=your_idealista_secret
CORS_ORIGINS=https://sfm7.github.io,http://localhost:5500

# Slack notifications (optional)
# 1. Create a Slack app at https://api.slack.com/apps
# 2. Enable "Incoming Webhooks" and add it to a channel
# 3. Copy the webhook URL below
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_NEW_THRESHOLD=2    # notify only if >= 2 new listings found
SLACK_DROP_THRESHOLD=1   # notify if >= 1 price drop detected
DASHBOARD_URL=https://sfm7.github.io/madrid-tracker/dashboard/
